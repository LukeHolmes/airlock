{
  "name": "@airlock/sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Airlock sandbox container - KasmVNC + Alpine Linux for isolated desktop streaming",
  "scripts": {
    "build": "docker build -t airlock/sandbox:latest .",
    "build:verbose": "docker build --progress=plain -t airlock/sandbox:latest .",
    "test": "docker run --rm -it --network none --cap-drop ALL -p 6901:6901 airlock/sandbox:latest"
  },
  "files": [
    "Dockerfile",
    "entrypoint.sh",
    "supervisord.conf",
    "launch-target.sh",
    "cleanup.sh"
  ]
}