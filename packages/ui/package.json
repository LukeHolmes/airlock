{
  "name": "@airlock/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main/index.js",
  "electronmon": {
    "patterns": [
      "dist/main/**/*.js",
      "dist/preload/**/*.js"
    ],
    "env": {
      "NODE_ENV": "development",
      "VITE_DEV_SERVER_URL": "http://localhost:5173"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prestart": "pnpm --filter @airlock/core build",
    "start": "electron .",
    "dev:prepare": "pnpm --filter @airlock/core build && npm run build:main && npm run build:preload",
    "dev:vite": "vite",
    "dev:watch:main": "tsc -p tsconfig.main.json -w --preserveWatchOutput",
    "dev:watch:preload": "tsc -p tsconfig.preload.json -w --preserveWatchOutput",
    "dev:electron": "wait-on http://localhost:5173 dist/main/main/index.js && electronmon .",
    "electron:dev": "npm run dev:prepare && concurrently -k \"npm:dev:vite\" \"npm:dev:watch:main\" \"npm:dev:watch:preload\" \"npm:dev:electron\"",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@airlock/core": "workspace:*",
    "electron": "^42.3.3",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.378.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.3",
    "electronmon": "^2.0.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.5"
  }
}
