{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/preload",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true
  },
  "include": ["src/preload/**/*", "src/shared/**/*"],
  "exclude": ["dist", "node_modules", "src/main/**/*", "src/renderer/**/*"]
}
