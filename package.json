{
  "name": "airlock",
  "private": true,
  "version": "0.1.0",
  "engines": { "node": ">=20", "pnpm": ">=9" },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/*/src --ext .ts,.tsx --ignore-pattern '**/_ref/**'",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix --ignore-pattern '**/_ref/**'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}' --ignore-path .prettierignore",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}' --ignore-path .prettierignore",
    "ci:lint": "pnpm lint && pnpm format:check",
    "ci:docker": "docker build -t airlock/sandbox:test ./packages/sandbox"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.5.0"
  }
}